generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SALESPERSON
}



model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SALESPERSON)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  configurations Configuration[]

  @@map("users")
}

model PartCategory {
  id               String   @id @default(uuid())
  name             String   @unique
  isRequired       Boolean  @default(true)
  requiredQuantity Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  // Relations
  parts Part[]

  @@map("part_categories")
}

model Part {
  id           String   @id @default(uuid())
  categoryId   String
  name         String   @unique
  description  String?
  currentPrice Int      // Stored in paise — never use Float
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Relations
  category           PartCategory        @relation(fields: [categoryId], references: [id])
  configurationParts ConfigurationPart[]

  @@map("parts")
}

model Configuration {
  id          String   @id @default(uuid())
  name        String
  description String?
  basePrice   Int      // Stored in paise
  createdBy   String
  gstPercent  Int      @default(1200) 
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  creator User                @relation(fields: [createdBy], references: [id])
  parts   ConfigurationPart[]

  @@map("configurations")
}

model ConfigurationPart {
  id              String @id @default(uuid())
  configurationId String
  partId          String
  quantity        Int    @default(1)

  // Relations
  configuration Configuration @relation(fields: [configurationId], references: [id])
  part          Part          @relation(fields: [partId], references: [id])

  @@unique([configurationId, partId])
  @@map("configuration_parts")
}
